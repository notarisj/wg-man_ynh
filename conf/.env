PORT=__PORT__
NODE_ENV=production

# WireGuard
WG_CONFIG_DIR=__WG_CONFIG_DIR__
WG_CONFIG_PATTERN=__WG_CONFIG_PATTERN__
WG_STATIC_INTERFACE=__WG_STATIC_INTERFACE__

# Monitor script — see /usr/local/bin/vpn-monitor.sh for the default stub
MONITOR_SCRIPT=__MONITOR_SCRIPT__
LOG_FILE=__LOG_FILE__

# State file: records the currently active tunnel config name
STATE_FILE=__DATA_DIR__/state.current

# Connectivity check
CHECK_IP=__CHECK_IP__
MAX_HANDSHAKE_AGE=120

# AUTH-01: shared secret between nginx and the backend
PROXY_SECRET=__PROXY_SECRET__

# Session secret for Dex OIDC session storage (generated at install time)
SESSION_SECRET=__SESSION_SECRET__

# Optional: Dex OIDC — leave empty to disable the Dex login button.
# Register wg-man as a client in Dex with redirect URI:
#   https://__DOMAIN____PATH__/api/auth/callback
# Then fill in the values below.
APP_PUBLIC_URL=https://__DOMAIN____PATH__
DEX_ISSUER=
DEX_CLIENT_ID=
DEX_CLIENT_SECRET=
