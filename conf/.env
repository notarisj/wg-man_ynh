PORT=__PORT__
NODE_ENV=production

# WireGuard
WG_CONFIG_DIR=__WG_CONFIG_DIR__
WG_CONFIG_PATTERN=__WG_CONFIG_PATTERN__
WG_STATIC_INTERFACE=__WG_STATIC_INTERFACE__

# Monitor script — see /usr/local/bin/vpn-monitor.sh for the default stub
MONITOR_SCRIPT=__MONITOR_SCRIPT__
LOG_FILE=__LOG_FILE__

# State file: records the currently active tunnel config name
STATE_FILE=__DATA_DIR__/state.current

# Connectivity check
CHECK_IP=__CHECK_IP__
MAX_HANDSHAKE_AGE=120
