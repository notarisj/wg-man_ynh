# Server
PORT=3001
NODE_ENV=production

# WireGuard
WG_CONFIG_DIR=/etc/wireguard
WG_CONFIG_PATTERN=nl-ams-wg-*.conf
WG_STATIC_INTERFACE=wg-vpn
MONITOR_SCRIPT=/home/notaris/scripts/vpn-monitor.sh
LOG_FILE=/var/log/vpn-monitor.log
STATE_FILE=/var/lib/vpn-monitor.current

# Ping check target
CHECK_IP=1.1.1.1
MAX_HANDSHAKE_AGE=120
