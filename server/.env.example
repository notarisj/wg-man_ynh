# Server
PORT=3001
NODE_ENV=production

# WireGuard
WG_CONFIG_DIR=/etc/wireguard
WG_CONFIG_PATTERN=wg-*.conf
WG_STATIC_INTERFACE=wg-vpn
MONITOR_SCRIPT=/usr/local/bin/vpn-monitor.sh
LOG_FILE=/var/log/vpn-monitor.log
STATE_FILE=/var/lib/vpn-monitor.current

# Ping check target
CHECK_IP=1.1.1.1
MAX_HANDSHAKE_AGE=150

# AUTH-01: shared secret between nginx and the backend (generate with: openssl rand -hex 24)
PROXY_SECRET=

# Session secret for Dex OIDC session storage (generate with: openssl rand -hex 32)
SESSION_SECRET=

# SEC-07: max concurrent WebSocket connections (default: 10)
MAX_WS_CLIENTS=10

# Optional: Dex OIDC — leave empty to disable the Dex login button.
# SEC-01: ALLOWED_GROUPS controls which YunoHost groups can authenticate via Dex.
# Must match the YunoHost app permission group (default: admins).
ALLOWED_GROUPS=admins
APP_PUBLIC_URL=https://your.domain/wg-man
DEX_ISSUER=
DEX_CLIENT_ID=
DEX_CLIENT_SECRET=
