#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# GENERATE PROXY SECRET (AUTH-01)
#=================================================
proxy_secret=$(ynh_string_random --length=48)
ynh_app_setting_set --key=proxy_secret --value="$proxy_secret"

#=================================================
# GENERATE SESSION SECRET
#=================================================
session_secret=$(ynh_string_random --length=64)
ynh_app_setting_set --key=session_secret --value="$session_secret"

#=================================================
# PREPARE DEX OIDC VARIABLES (for .env substitution)
# dex_domain is set by the install question; empty means no Dex integration.
#=================================================
dex_issuer=""
dex_client_id=""
dex_client_secret=""

if [ -n "$dex_domain" ]; then
    dex_client_secret=$(ynh_string_random --length=32)
    ynh_app_setting_set --key=dex_client_secret --value="$dex_client_secret"
    dex_client_id="$app"
    dex_issuer="https://${dex_domain}/"
fi

#=================================================
# INSTALL NODE.JS
#=================================================
ynh_script_progression "Installing Node.js $nodejs_version..."
ynh_install_nodejs --nodejs_version="$nodejs_version"
ynh_use_nodejs
# Save the resolved node binary path so conf/systemd.service can reference it via __NODE__
ynh_app_setting_set --key=node --value="$ynh_node"
# Also expose as a bash variable so ynh_replace_vars can substitute __NODE__ in conf templates
node="$ynh_node"

#=================================================
# COPY APPLICATION SOURCE
#=================================================
ynh_script_progression "Copying application source..."

# Copy repo contents to install_dir, excluding packaging and build artefacts
rsync -a \
    --exclude='.git' \
    --exclude='scripts' \
    --exclude='conf' \
    --exclude='manifest.toml' \
    --exclude='node_modules' \
    --exclude='server/node_modules' \
    --exclude='dist' \
    --exclude='server/dist' \
    "$YNH_APP_BASEDIR/" "$install_dir/"

#=================================================
# BUILD FRONTEND
#=================================================
ynh_script_progression "Building frontend (vite)..."
pushd "$install_dir"
# VITE_APP_PATH sets the Vite `base` option so assets and routes use the correct sub-path
VITE_APP_PATH="$path/" $ynh_npm ci 2>&1
VITE_APP_PATH="$path/" $ynh_npm run build 2>&1
# PKG-03: remove dev dependencies after build — the compiled output is in dist/
$ynh_npm prune --production 2>&1
popd

#=================================================
# BUILD BACKEND
#=================================================
ynh_script_progression "Building backend (TypeScript)..."
pushd "$install_dir/server"
$ynh_npm ci 2>&1
$ynh_npm run build 2>&1
# PKG-03: remove dev dependencies after build (typescript, @types/*, etc.)
$ynh_npm prune --production 2>&1
popd

#=================================================
# INSTALL DEFAULT MONITOR SCRIPT (IF ABSENT)
# SYS-02: ensure root ownership and no world-write
#=================================================
if [ ! -f "$monitor_script" ]; then
    ynh_script_progression "Installing default vpn-monitor.sh to $monitor_script..."
    install -o root -g root -m 755 "$YNH_APP_BASEDIR/conf/vpn-monitor.sh" "$monitor_script"
else
    # Ensure existing script is not world-writable
    chmod o-w "$monitor_script"
    chown root:root "$monitor_script"
fi

#=================================================
# CONFIGURE .env
# dex_issuer / dex_client_id / dex_client_secret are set above and will be
# substituted as __DEX_ISSUER__ / __DEX_CLIENT_ID__ / __DEX_CLIENT_SECRET__
#=================================================
ynh_script_progression "Writing .env configuration..."
ynh_add_config --template=".env" --destination="$install_dir/server/.env"
chmod 640 "$install_dir/server/.env"

#=================================================
# REGISTER AS DEX OIDC CLIENT
# Write a static-client stanza into Dex's config.yaml.d/ directory and
# regenerate the Dex config so the new client is active immediately.
#=================================================
if [ -n "$dex_domain" ]; then
    ynh_script_progression "Registering $app as a Dex OIDC static client..."

    mkdir -p /var/www/dex/config.yaml.d

    # dex-client.yaml template uses __APP__, __DOMAIN__, __PATH__, __DEX_CLIENT_SECRET__
    ynh_add_config \
        --template="dex-client.yaml" \
        --destination="/var/www/dex/config.yaml.d/${app}.yaml"
    chmod 640 "/var/www/dex/config.yaml.d/${app}.yaml"

    # Regenerate the Dex config.yaml from head + config.yaml.d fragments
    if [ -x /var/www/dex/regenerate_config.sh ]; then
        bash /var/www/dex/regenerate_config.sh
    fi

    # Reload Dex so it picks up the new client
    ynh_systemd_action --service_name=dex --action=restart
fi

#=================================================
# SET FILE PERMISSIONS
#=================================================
# PKG-01: set install_dir to root:root 750 so other system users cannot read
# application files or the .env (which contains PROXY_SECRET / SESSION_SECRET).
chown -R root:root "$install_dir"
chmod -R 750 "$install_dir"
chmod 640 "$install_dir/server/.env"

# The service runs as root (wg-quick requires CAP_NET_ADMIN), so the data
# directory must be accessible by root.
chown root:root "$data_dir"
chmod 750 "$data_dir"

#=================================================
# INSTALL APP ICON INTO YUNOHOST PORTAL
#=================================================
if [ -f "$YNH_APP_BASEDIR/doc/icon.png" ]; then
    icon_hash=$(sha256sum "$YNH_APP_BASEDIR/doc/icon.png" | cut -d' ' -f1)
    mkdir -p /usr/share/yunohost/applogos
    cp "$YNH_APP_BASEDIR/doc/icon.png" "/usr/share/yunohost/applogos/${icon_hash}.png"
    yunohost app setting "$app" _permissions.main.logo_hash -v "$icon_hash"
fi

#=================================================
# CONFIGURE NGINX
#=================================================
ynh_script_progression "Configuring nginx..."
ynh_add_nginx_config

#=================================================
# CONFIGURE SYSTEMD
#=================================================
ynh_script_progression "Configuring systemd service..."
ynh_add_systemd_config
yunohost service add "$app" --description="WireGuard VPN Manager" --log="/var/log/$app.log"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Starting $app..."
ynh_systemd_action --service_name="$app" --action="start"

ynh_script_progression "Installation of $app completed"
