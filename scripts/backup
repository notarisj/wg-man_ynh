#!/bin/bash
source /usr/share/yunohost/helpers

ynh_script_progression "Backing up $app..."

# Back up the full install directory (includes built dist and node_modules).
# Guard against install_dir being absent (e.g. after a partially-failed
# prior upgrade) so a pre-upgrade backup doesn't itself fail and block recovery.
if [ -d "$install_dir" ]; then
    ynh_backup "$install_dir"
else
    ynh_print_warn "install_dir $install_dir does not exist — skipping its backup"
fi

# Back up the data directory (VPN state file)
ynh_backup "$data_dir"

ynh_script_progression "Backup of $app completed"
