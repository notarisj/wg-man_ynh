#!/bin/bash
source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

#=================================================
# RESTORE APP FILES
#=================================================
ynh_script_progression "Reinstalling Node.js $nodejs_version..."
ynh_nodejs_install --nodejs_version="$nodejs_version"
node=$(which node)

ynh_script_progression "Restoring application files..."
ynh_restore "$install_dir"
ynh_restore "$data_dir"

#=================================================
# FIX PERMISSIONS
#=================================================
chown -R root:root "$install_dir"
chmod -R 750 "$install_dir"
chmod 640 "$install_dir/server/.env"

chown root:root "$data_dir"
chmod 750 "$data_dir"

#=================================================
# RESTORE DEX OIDC CLIENT
#=================================================
if [ -n "$dex_domain" ]; then
    ynh_script_progression "Restoring Dex OIDC client registration..."
    mkdir -p /var/www/dex/config.yaml.d
    ynh_config_add \
        --template="dex-client.yaml" \
        --destination="/var/www/dex/config.yaml.d/${app}.yaml"
    chmod 640 "/var/www/dex/config.yaml.d/${app}.yaml"
    if [ -x /var/www/dex/regenerate_config.sh ]; then
        bash /var/www/dex/regenerate_config.sh
    fi
    ynh_systemctl --service=dex --action=restart
fi

#=================================================
# RESTORE NGINX AND SYSTEMD
#=================================================
ynh_script_progression "Restoring nginx configuration..."
ynh_config_add_nginx

ynh_script_progression "Restoring systemd service..."
ynh_config_add_systemd
yunohost service add "$app" --description="WireGuard VPN Manager" --log="/var/log/$app.log"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Starting $app..."
ynh_systemctl --service="$app" --action="start"

ynh_systemctl --service=nginx --action=reload

ynh_script_progression "Restoration of $app completed"
