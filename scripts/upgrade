#!/bin/bash
source _common.sh
source /usr/share/yunohost/helpers

#=================================================
# STOP SERVICE
#=================================================
ynh_script_progression "Stopping $app for upgrade..."
ynh_systemd_action --service_name="$app" --action="stop"

#=================================================
# GENERATE PROXY SECRET IF MISSING (AUTH-01)
#=================================================
proxy_secret=$(ynh_app_setting_get --key=proxy_secret)
if [ -z "$proxy_secret" ]; then
    proxy_secret=$(ynh_string_random --length=48)
    ynh_app_setting_set --key=proxy_secret --value="$proxy_secret"
fi

#=================================================
# GENERATE SESSION SECRET IF MISSING
#=================================================
session_secret=$(ynh_app_setting_get --key=session_secret)
if [ -z "$session_secret" ]; then
    session_secret=$(ynh_string_random --length=64)
    ynh_app_setting_set --key=session_secret --value="$session_secret"
fi

#=================================================
# PREPARE DEX OIDC VARIABLES
# dex_domain is saved in app settings from install time.
#=================================================
dex_issuer=""
dex_client_id=""
dex_client_secret=""

if [ -n "$dex_domain" ]; then
    # Preserve the existing client secret across upgrades
    dex_client_secret=$(ynh_app_setting_get --key=dex_client_secret)
    if [ -z "$dex_client_secret" ]; then
        dex_client_secret=$(ynh_string_random --length=32)
        ynh_app_setting_set --key=dex_client_secret --value="$dex_client_secret"
    fi
    dex_client_id="$app"
    dex_issuer="https://${dex_domain}/"
fi

#=================================================
# INSTALL / UPDATE NODE.JS
#=================================================
ynh_script_progression "Updating Node.js $nodejs_version..."
ynh_install_nodejs --nodejs_version="$nodejs_version"
ynh_use_nodejs
ynh_app_setting_set --key=node --value="$ynh_node"
node="$ynh_node"

#=================================================
# UPDATE APPLICATION SOURCE
#=================================================
ynh_script_progression "Updating application source..."

rsync -a \
    --exclude='.git' \
    --exclude='scripts' \
    --exclude='conf' \
    --exclude='manifest.toml' \
    --exclude='node_modules' \
    --exclude='server/node_modules' \
    --exclude='dist' \
    --exclude='server/dist' \
    "$YNH_APP_BASEDIR/" "$install_dir/"

#=================================================
# REBUILD FRONTEND
#=================================================
ynh_script_progression "Rebuilding frontend..."
pushd "$install_dir"
VITE_APP_PATH="$path/" $ynh_npm ci 2>&1
VITE_APP_PATH="$path/" $ynh_npm run build 2>&1
# PKG-03: remove dev dependencies after build
$ynh_npm prune --production 2>&1
popd

#=================================================
# REBUILD BACKEND
#=================================================
ynh_script_progression "Rebuilding backend..."
pushd "$install_dir/server"
$ynh_npm ci 2>&1
$ynh_npm run build 2>&1
# PKG-03: remove dev dependencies after build (typescript, @types/*, etc.)
$ynh_npm prune --production 2>&1
popd

#=================================================
# UPDATE CONFIGURATIONS
#=================================================
ynh_script_progression "Updating nginx configuration..."
ynh_add_nginx_config

ynh_script_progression "Updating systemd service..."
ynh_add_systemd_config

ynh_script_progression "Updating .env configuration..."
ynh_add_config --template=".env" --destination="$install_dir/server/.env"
chmod 640 "$install_dir/server/.env"

#=================================================
# UPDATE DEX OIDC CLIENT
# Rewrite the client config in case the redirect URI changed (e.g. path change).
#=================================================
if [ -n "$dex_domain" ]; then
    ynh_script_progression "Updating Dex OIDC client registration..."

    mkdir -p /var/www/dex/config.yaml.d

    ynh_add_config \
        --template="dex-client.yaml" \
        --destination="/var/www/dex/config.yaml.d/${app}.yaml"
    chmod 640 "/var/www/dex/config.yaml.d/${app}.yaml"

    if [ -x /var/www/dex/regenerate_config.sh ]; then
        bash /var/www/dex/regenerate_config.sh
    fi
    ynh_systemd_action --service_name=dex --action=restart
fi

#=================================================
# FIX PERMISSIONS
#=================================================
# PKG-01: set install_dir to root:root 750
chown -R root:root "$install_dir"
chmod -R 750 "$install_dir"
chmod 640 "$install_dir/server/.env"

# Ensure data_dir is root-owned (service runs as root).
chown root:root "$data_dir"
chmod 750 "$data_dir"

#=================================================
# START SERVICE
#=================================================
ynh_script_progression "Restarting $app..."
ynh_systemd_action --service_name="$app" --action="start"

ynh_script_progression "Upgrade of $app completed"
